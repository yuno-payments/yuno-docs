                        "currency": {
                          "type": "string",
                          "example": "COP"
                        }
                      }
                    }
                  }
                },
                "terms_of_service": {
                  "type": "object",
                  "properties": {
                    "acceptance": {
                      "type": "boolean",
                      "example": true
                    },
                    "date": {
                      "type": "string",
                      "example": "2025-07-21T20:43:54Z"
                    },
                    "ip": {
                      "type": "string",
                      "example": "129.21.111.11"
                    }
                  }
                },
