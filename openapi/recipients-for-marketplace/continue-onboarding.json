                "requirements": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "field": {
                        "type": "string",
                        "example": "document.cc"
                      },
                      "message": {
                        "type": "string",
                        "example": "Provide CC document image"
                      },
