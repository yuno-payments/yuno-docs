{
  "openapi": "3.1.0",
  "info": {
    "title": "3ds-setup",
    "version": "1.0.2"
  },
  "servers": [
    {
      "url": "https://api-sandbox.y.uno/v1"
    }
  ],
  "components": {
    "securitySchemes": {
      "sec0": {
        "type": "apiKey",
        "in": "header",
        "name": "public-api-key",
        "x-default": "<Your public-api-key>"
      },
      "sec1": {
        "type": "apiKey",
        "in": "header",
        "name": "private-secret-key",
        "x-default": "<Your private-secret-key>"
      }
    }
  },
  "security": [
    {
      "sec0": [],
      "sec1": []
    }
  ],
  "paths": {
    "/tokens": {
      "post": {
        "summary": "Create One Time Use Token",
        "description": "",
        "operationId": "post_tokens",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "account_id",
                  "card_data"
                ],
                "properties": {
                  "account_id": {
                    "type": "string",
                    "description": "The unique identifier of the account. You find this information on Yuno's Dashboard (MAX 64; MIN 36).",
                    "example": "fe14c7c6-c75e-43b7-bdbe-4c87ad52c482"
                  },
                  "country": {
                    "type": "string",
                    "description": "Customer's country (ISO 3166-1 MAX 2; MIN 2).",
                    "example": "US"
                  },
                  "card_data": {
                    "type": "object",
                    "required": [
                      "number",
                      "expiration_month",
                      "expiration_year",
                      "holder_name"
                    ],
                    "properties": {
                      "number": {
                        "type": "string",
                        "description": "Card number without separators (MAX 19; MIN 8).",
                        "example": "4111111111111111"
                      },
                      "expiration_month": {
                        "type": "integer",
                        "description": "Card expiration month - MM.",
                        "example": 12
                      },
                      "expiration_year": {
                        "type": "integer",
                        "description": "Card expiration year - YY or YYYY.",
                        "example": 25
                      },
                      "security_code": {
                        "type": "string",
                        "description": "Card security code (MAX 4; MIN 2).",
                        "example": "123"
                      },
                      "holder_name": {
                        "type": "string",
                        "description": "Cardholder full name (MAX 26; MIN 3).",
                        "example": "John Doe"
                      },
                      "stored_credentials": {
                        "type": "object",
                        "properties": {
                          "reason": {
                            "type": "string",
                            "enum": [
                              "CARD_ON_FILE",
                              "SUBSCRIPTION",
                              "UNSCHEDULED_CARD_ON_FILE"
                            ]
                          },
                          "usage": {
                            "type": "string",
                            "enum": [
                              "FIRST",
                              "USED"
                            ]
                          },
                          "subscription_agreement_id": {
                            "type": "string"
                          },
                          "network_transaction_id": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  },
                  "customer_payer": {
                    "type": "object",
                    "properties": {
                      "first_name": {
                        "type": "string",
                        "example": "John"
                      },
                      "last_name": {
                        "type": "string",
                        "example": "Doe"
                      },
                      "email": {
                        "type": "string",
                        "format": "email",
                        "example": "johndoe@example.com"
                      },
                      "gender": {
                        "type": "string",
                        "enum": [
                          "M",
                          "F",
                          "NA",
                          "NK"
                        ]
                      },
                      "date_of_birth": {
                        "type": "string",
                        "format": "date",
                        "example": "1990-01-01"
                      },
                      "phone": {
                        "type": "object",
                        "required": [
                          "country_code",
                          "number"
                        ],
                        "properties": {
                          "country_code": {
                            "type": "string",
                            "example": "+1"
                          },
                          "number": {
                            "type": "string",
                            "example": "5551234567"
                          }
                        }
                      },
                      "billing_address": {
                        "type": "object",
                        "properties": {
                          "address_line_1": {
                            "type": "string"
                          },
                          "address_line_2": {
                            "type": "string"
                          },
                          "country": {
                            "type": "string",
                            "example": "US"
                          },
                          "state": {
                            "type": "string",
                            "example": "NY"
                          },
                          "city": {
                            "type": "string",
                            "example": "New York"
                          },
                          "zip_code": {
                            "type": "string",
                            "example": "10001"
                          },
                          "neighborhood": {
                            "type": "string"
                          }
                        }
                      },
                      "shipping_address": {
                        "type": "object"
                      },
                      "document": {
                        "type": "object",
                        "properties": {
                          "document_type": {
                            "type": "string",
                            "example": "PASS"
                          },
                          "document_number": {
                            "type": "string",
                            "example": "A12345678"
                          }
                        }
                      },
                      "browser_info": {
                        "type": "object",
                        "properties": {
                          "user_agent": {
                            "type": "string"
                          },
                          "accept_header": {
                            "type": "string"
                          },
                          "accept_content": {
                            "type": "string"
                          },
                          "accept_browser": {
                            "type": "string"
                          },
                          "color_depth": {
                            "type": "string"
                          },
                          "screen_height": {
                            "type": "string"
                          },
                          "screen_width": {
                            "type": "string"
                          },
                          "javascript_enabled": {
                            "type": "boolean"
                          },
                          "java_enabled": {
                            "type": "boolean"
                          },
                          "browser_time_difference": {
                            "type": "string"
                          },
                          "language": {
                            "type": "string"
                          },
                          "platform": {
                            "type": "string"
                          }
                        }
                      },
                      "nationality": {
                        "type": "string",
                        "example": "US"
                      },
                      "ip_address": {
                        "type": "string",
                        "example": "192.168.1.1"
                      },
                      "device_fingerprints": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "provider_id": {
                              "type": "string"
                            },
                            "id": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              },
              "examples": {
                "Request Example": {
                  "value": {
                    "account_id": "{{account_id}}",
                    "card_data": {
                      "number": "4111111111111111",
                      "expiration_month": 12,
                      "expiration_year": 29,
                      "security_code": "123",
                      "holder_name": "John Doe"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string",
                      "example": "9107a30f-564c-4469-bd7c-8e1f249fb016"
                    },
                    "card_data": {
                      "type": "object",
                      "properties": {
                        "holder_name": {
                          "type": "string",
                          "example": "John Doe"
                        },
                        "iin": {
                          "type": "string",
                          "example": "41111111"
                        },
                        "lfd": {
                          "type": "string",
                          "example": "1111"
                        },
                        "number_length": {
                          "type": "integer",
                          "example": 16
                        },
                        "security_code_length": {
                          "type": "integer",
                          "example": 3
                        },
                        "brand": {
                          "type": "string",
                          "example": "VISA"
                        },
                        "type": {
                          "type": "string",
                          "example": "DEBIT"
                        },
                        "category": {
                          "type": "string",
                          "example": "CLASSIC"
                        },
                        "issuer_name": {
                          "type": "string",
                          "example": "CONOTOXIA SP Z O O"
                        },
                        "issuer_code": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "example": null
                        },
                        "fingerprint": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "example": null
                        }
                      }
                    },
                    "customer_payer": {
                      "type": "object",
                      "properties": {
                        "first_name": {
                          "type": "string",
                          "example": "John"
                        },
                        "last_name": {
                          "type": "string",
                          "example": "Doe"
                        },
                        "email": {
                          "type": "string",
                          "format": "email",
                          "example": "johndoe@example.com"
                        },
                        "gender": {
                          "type": "string",
                          "enum": [
                            "M",
                            "F",
                            "NA",
                            "NK"
                          ]
                        },
                        "date_of_birth": {
                          "type": "string",
                          "format": "date",
                          "example": "1990-01-01"
                        },
                        "phone": {
                          "type": "object",
                          "properties": {
                            "number": {
                              "type": "string",
                              "example": "5551234567"
                            },
                            "country_code": {
                              "type": "string",
                              "example": "1"
                            }
                          }
                        },
                        "billing_address": {
                          "type": "object",
                          "properties": {
                            "address_line_1": {
                              "type": "string",
                              "example": "123 Main St"
                            },
                            "address_line_2": {
                              "type": "string",
                              "example": "Apt 4B"
                            },
                            "country": {
                              "type": "string",
                              "example": "US"
                            },
                            "state": {
                              "type": "string",
                              "example": "NY"
                            },
                            "city": {
                              "type": "string",
                              "example": "New York"
                            },
                            "zip_code": {
                              "type": "string",
                              "example": "10001"
                            },
                            "neighborhood": {
                              "type": [
                                "string",
                                "null"
                              ],
                              "example": null
                            }
                          }
                        },
                        "shipping_address": {
                          "type": [
                            "object",
                            "null"
                          ],
                          "example": null
                        },
                        "document": {
                          "type": "object",
                          "properties": {
                            "document_type": {
                              "type": [
                                "string",
                                "null"
                              ],
                              "example": null
                            },
                            "document_number": {
                              "type": [
                                "string",
                                "null"
                              ],
                              "example": null
                            }
                          }
                        },
                        "browser_info": {
                          "type": "object",
                          "properties": {
                            "user_agent": {
                              "type": "string",
                              "example": "Mozilla/5.0 ..."
                            },
                            "accept_header": {
                              "type": "string",
                              "example": "text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8"
                            },
                            "accept_content": {
                              "type": [
                                "string",
                                "null"
                              ],
                              "example": null
                            },
                            "accept_browser": {
                              "type": [
                                "string",
                                "null"
                              ],
                              "example": null
                            },
                            "color_depth": {
                              "type": "string",
                              "example": "24"
                            },
                            "screen_height": {
                              "type": "string",
                              "example": "1080"
                            },
                            "screen_width": {
                              "type": "string",
                              "example": "1920"
                            },
                            "javascript_enabled": {
                              "type": "boolean",
                              "example": true
                            },
                            "java_enabled": {
                              "type": [
                                "boolean",
                                "null"
                              ],
                              "example": null
                            },
                            "browser_time_difference": {
                              "type": [
                                "string",
                                "null"
                              ],
                              "example": null
                            },
                            "language": {
                              "type": "string",
                              "example": "en-US"
                            },
                            "platform": {
                              "type": [
                                "string",
                                "null"
                              ],
                              "example": null
                            }
                          }
                        },
                        "nationality": {
                          "type": "string",
                          "example": "US"
                        },
                        "ip_address": {
                          "type": "string",
                          "example": "192.168.1.1"
                        },
                        "device_fingerprints": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "provider_id": {
                                "type": "string",
                                "example": "DLOCAL"
                              },
                              "id": {
                                "type": "string",
                                "example": "abc123xyz"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "Result": {
                    "value": {
                      "token": "9107a30f-564c-4469-bd7c-8e1f249fb016",
                      "card_data": {
                        "holder_name": "John Doe",
                        "iin": "41111111",
                        "lfd": "1111",
                        "number_length": 16,
                        "security_code_length": 3,
                        "brand": "VISA",
                        "type": "DEBIT",
                        "category": "CLASSIC",
                        "issuer_name": "CONOTOXIA SP Z O O",
                        "issuer_code": null,
                        "fingerprint": null
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string",
                      "example": "INVALID_REQUEST"
                    },
                    "messages": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                },
                "examples": {
                  "Invalid Request": {
                    "value": {
                      "code": "INVALID_REQUEST",
                      "messages": [
                        "Invalid request"
                      ]
                    },
                    "summary": "Invalid Request"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string",
                      "example": "INVALID_CREDENTIALS"
                    },
                    "messages": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                },
                "examples": {
                  "Unauthorized": {
                    "value": {
                      "code": "INVALID_CREDENTIALS",
                      "messages": [
                        "Invalid credentials"
                      ]
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string",
                      "example": "AUTHORIZATION_REQUIRED"
                    },
                    "messages": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                },
                "examples": {
                  "Forbidden": {
                    "value": {
                      "code": "AUTHORIZATION_REQUIRED",
                      "messages": [
                        "The merchant has no authorization to use this API."
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "parameters": []
      }
    }
  },
  "x-readme": {
    "headers": [
      {
        "key": "charset",
        "value": "utf-8"
      }
    ],
    "explorer-enabled": true,
    "proxy-enabled": true
  },
  "x-readme-fauxas": true
}