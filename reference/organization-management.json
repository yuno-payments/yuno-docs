                    "type": "string",
                    "example": "John"
                  },
                  "last_name": {
                    "type": "string",
                    "example": "Doe"
                  },
                  "account_permissions": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "account_id": {
                          "type": "string",
                          "format": "uuid",
                          "example": "a1b2c3d4-..."
                        },
                        "role_id": {
                          "type": "string",
