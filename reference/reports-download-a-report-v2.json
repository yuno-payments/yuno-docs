            "schema": {
              "type": "string"
            },
            "description": "Organization code associated to the request."
          },
          {
            "name": "report_id",
            "in": "path",
            "required": true,
            "description": "The report unique identifier.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "200",
            "content": {
              "application/json": {
                "examples": {
                  "Result": {
                    "value": "{\n  \"type\": \"TRANSACTIONS\",\n  \"download_link\": \"https://s3.amazonaws.com/.../report.csv\",\n  \"status\": \"AVAILABLE\"\n}"
                  }
                },
                "schema": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "example": "TRANSACTIONS"
                    },
                    "download_link": {
                      "type": "string",
                      "example": "https://s3.amazonaws.com/.../report.csv"
                    },
                    "status": {
                      "type": "string",
                      "example": "AVAILABLE"
                    }
                  }
                }
              }
            }
          },
          "400": {
