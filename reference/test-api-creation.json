    "/recipients/{recipient_id}/onboardings/{onboarding_id}/accounts": {
      "post": {
        "summary": "New Endpoint",
        "description": "This is your first endpoint! Edit this page to start documenting your API.",
        "responses": {
          "200": {
            "description": "Successful response"
          }
        },
        "parameters": [
          {
            "in": "path",
            "name": "recipient_id",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "ID of the recipient"
          },
          {
            "in": "path",
            "name": "onboarding_id",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "ID of the onboarding "
          }
        ],
        "operationId": "post_recipients-recipient-id-onboardings-onboarding-id-accounts",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "account_id": {
                    "type": "string",
                    "description": "Unique id of the account in Yuno"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "CHECKING",
                      "SAVINGS",
                      "CURRENT"
                    ],
                    "description": "The functional category of the bank account",
                    "default": "CHECKING"
                  },
                  "description": {
                    "type": "string",
                    "description": "Optional description of the account (MAX 255; MIN 3).\n"
                  },
                  "provider": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "Provider id"
                      },
                      "connection_id": {
                        "type": "string",
                        "description": "Id of the connection in Yuno"
                      }
                    },
                    "required": [
                      "id",
                      "connection_id"
                    ]
                  }
                },
                "required": [
                  "account_id",
                  "provider"
                ]
              }
            }
          }
        }
      }
    }
