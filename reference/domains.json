{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "Domains"
  },
  "servers": [
    {
      "url": "https://api-sandbox.y.uno"
    }
  ],
  "tags": [],
  "paths": {
    "/new-endpoint": {
      "get": {
        "summary": "New Endpoint",
        "description": "This is your first endpoint! Edit this page to start documenting your API.",
        "operationId": "get_new-endpoint",
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      }
    },
    "/v1/payment-methods/domains": {
      "post": {
        "description": "",
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "account_id": {
                      "type": "string",
                      "example": "3fa85f64-5717-4562-b3fc-2c963f66afa6"
                    },
                    "payment_method": {
                      "type": "string",
                      "example": "APPLE_PAY"
                    },
                    "domains": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "example": "dom_1234567890abcdef"
                          },
                          "domain": {
                            "type": "string",
                            "example": "checkout.example.com"
                          },
                          "status": {
                            "type": "string",
                            "example": "REGISTERED"
                          },
                          "created_at": {
                            "type": "string",
                            "example": "2026-01-22T10:30:00Z"
                          },
                          "updated_at": {
                            "type": "string",
                            "example": "2026-01-22T10:30:00Z"
                          }
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "Accepted": {
                    "summary": "Accepted",
                    "value": {
                      "account_id": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
                      "payment_method": "APPLE_PAY",
                      "domains": [
                        {
                          "id": "dom_1234567890abcdef",
                          "domain": "checkout.example.com",
                          "status": "REGISTERED",
                          "created_at": "2026-01-22T10:30:00Z",
                          "updated_at": "2026-01-22T10:30:00Z"
                        },
                        {
                          "id": "dom_3456789012cdefgh",
                          "domain": "shop.example.com",
                          "status": "REGISTERED",
                          "created_at": "2026-01-22T10:30:00Z",
                          "updated_at": "2026-01-22T10:30:00Z"
                        }
                      ]
                    }
                  }
                }
              }
            },
            "description": "Accepted"
          }
        },
        "parameters": [
          {
            "in": "header",
            "name": "X-Idempotency-Key",
            "schema": {
              "type": "string"
            }
          }
        ],
        "operationId": "post_v1-payment-methods-domains",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "account_id": {
                    "type": "string"
                  },
                  "connection_id": {
                    "type": "string"
                  },
                  "payment_method_type": {
                    "type": "string"
                  },
                  "domains": {
                    "type": "array",
                    "items": {
                      "properties": {
                        "url": {
                          "type": "string"
                        }
                      },
                      "type": "object"
                    }
                  }
                },
                "required": [
                  "account_id"
                ]
              },
              "examples": {
                "Accepted": {
                  "summary": "Accepted",
                  "value": {
                    "account_id": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
                    "connection_id": "7c1d9a2e-3f44-4e8a-9b61-8e2f4c6b9d0a",
                    "payment_method_type": "APPLE_PAY",
                    "domains": [
                      {
                        "url": "checkout.example.com"
                      },
                      {
                        "url": "shop.example.com"
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/payment-method-domains/{id}": {
      "get": {
        "description": "",
        "responses": {
          "200": {
            "description": ""
          }
        },
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "schema": {
              "type": "string"
            },
            "required": true
          },
          {
            "in": "query",
            "name": "account_id",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "domain",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "payment_method",
            "schema": {
              "type": "string"
            }
          }
        ],
        "operationId": "get_v1-payment-method-domains-id"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "public-api-key": {
        "type": "apiKey",
        "in": "header",
        "name": "public-api-key"
      },
      "private-secret-key": {
        "type": "apiKey",
        "in": "header",
        "name": "private-secret-key"
      }
    }
  },
  "x-readme": {
    "explorer-enabled": true,
    "proxy-enabled": true
  },
  "security": [
    {
      "public-api-key": [],
      "private-secret-key": []
