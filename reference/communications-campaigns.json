                      },
                      "daily_end_time": {
                        "type": "string",
                        "description": "End of daily send window in `HH:MM` format."
                      },
                      "time_zone": {
                        "type": "string",
                        "description": "IANA timezone (e.g., `America/Bogota`) or UTC offset (e.g., `-05:00`)"
