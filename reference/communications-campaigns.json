                          "items": {
                            "type": "string"
                          },
                          "description": "Array of string values for comparison. Not required for `UNIQUE_BY_USER`."
                        },
                        "conditional": {
                          "type": "string",
                          "description": "Comparison operator. Not required for `USER_COMMS_PER_DAY` or `UNIQUE_BY_USER`. See [Conditional Operators Reference](ref:communications-campaigns#conditional-operators-reference)."
