                        "type": "string",
                        "description": "Campaign start date in ISO 8601 format."
                      },
                      "end_at": {
                        "type": "string",
                        "description": "Campaign end date in ISO 8601 format. Must be after `start_at`."
                      }
                    },
                    "required": [
                      "end_at",
                      "start_at"
                    ],
                    "description": "Campaign active period."
                  }
                },
                "required": [
                  "name",
                  "duration",
                  "schedule",
                  "channel",
                  "country",
                  "organization_code",
                  "account_id"
